# Market data provider configuration (server-side only)
MARKET_DATA_PROVIDER=finnhub

# Finnhub API key — never expose client-side or commit the real value.
# For Vercel: Project Settings → Environment Variables → FINNHUB_API_KEY
FINNHUB_API_KEY=your_finnhub_api_key

# Optional: use mock provider for local UI development without an API key
# MARKET_DATA_PROVIDER=mock
