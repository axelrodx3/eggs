# Market data provider configuration (server-side only)
MARKET_DATA_PROVIDER=twelve-data

# Twelve Data API key — never expose client-side or commit the real value.
# For Vercel: Project Settings → Environment Variables → TWELVE_DATA_API_KEY
TWELVE_DATA_API_KEY=

# Optional: use mock provider for local UI development without an API key
# MARKET_DATA_PROVIDER=mock
